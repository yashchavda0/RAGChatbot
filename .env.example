# ==============================================================================
# RAG Chatbot - Environment Variables
# ==============================================================================

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# Database - PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/rag_chatbot
# Alternative format:
# POSTGRES_URL=postgresql://user:password@host:port/database

# -----------------------------------------------------------------------------
# Vector Database - Milvus
# -----------------------------------------------------------------------------
MILVUS_HOST=localhost
MILVUS_PORT=19530

# -----------------------------------------------------------------------------
# Cache - Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Web Search - Tavily
# -----------------------------------------------------------------------------
TAVILY_API_KEY=your_tavily_api_key_here

# -----------------------------------------------------------------------------
# Embedding Models (all 3 used simultaneously)
# -----------------------------------------------------------------------------
EMBEDDING_MODELS=bge-small,bge-large,stella
DEFAULT_EMBEDDING_MODEL=bge-large-en-v1.5

# -----------------------------------------------------------------------------
# Reranker
# -----------------------------------------------------------------------------
RERANKER_MODEL=bge-reranker-v2-m3
RERANKER_TOP_K=10

# -----------------------------------------------------------------------------
# LLM Settings
# -----------------------------------------------------------------------------
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=1024

# -----------------------------------------------------------------------------
# Tavily Settings
# -----------------------------------------------------------------------------
TAVILY_MAX_RESULTS=10

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
INTEGRATION_API_KEY=change-this-in-production

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Document Processing
# -----------------------------------------------------------------------------
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MAX_FILE_SIZE_MB=50
