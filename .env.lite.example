# ========================================
# LIGHTWEIGHT MODE ENVIRONMENT VARIABLES
# ========================================
# Copy this to .env and fill in your values

# ----- REQUIRED -----

# Gemini API (for LLM and embeddings)
GEMINI_API_KEY=your_gemini_api_key_here

# Tavily API (for web search)
TAVILY_API_KEY=your_tavily_api_key_here

# Azure Document Intelligence (for OCR)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your_azure_key_here

# ----- OPTIONAL (defaults provided) -----

# PostgreSQL (for LangGraph checkpointer)
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
POSTGRES_URL=postgresql://raguser:ragpassword@localhost:5432/rag_chatbot

# Redis
REDIS_URL=redis://localhost:6379/0

# API Security
INTEGRATION_API_KEY=change-this-to-secure-random-string

# ChromaDB
CHROMADB_PERSIST_DIR=./data/chromadb

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# ----- NOT NEEDED IN LITE MODE -----
# MILVUS_HOST=localhost
# MILVUS_PORT=19530
# (ChromaDB is used instead, no setup required)

# EMBEDDING_DEVICE=cpu
# (Uses Gemini API, no local models)
